{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grokify/structured-profile/schema/matcheval.schema.json",
  "title": "MatchEvaluation",
  "description": "Job-to-profile match evaluation schema for structured-profile, built on structured-evaluation conventions",
  "type": "object",
  "required": ["metadata", "job", "profile", "match", "decision"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "metadata": {
      "$ref": "#/$defs/MatchMetadata"
    },
    "job": {
      "$ref": "#/$defs/JobSummary"
    },
    "profile": {
      "$ref": "#/$defs/ProfileSummary"
    },
    "match": {
      "$ref": "#/$defs/MatchResult"
    },
    "decision": {
      "$ref": "#/$defs/MatchDecision"
    },
    "nextSteps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ActionItem"
      }
    }
  },
  "$defs": {
    "MatchMetadata": {
      "type": "object",
      "required": ["evaluationId", "generatedAt", "generatedBy", "schemaVersion"],
      "properties": {
        "evaluationId": {
          "type": "string",
          "description": "Unique evaluation identifier"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "generatedBy": {
          "type": "string",
          "description": "Agent or pipeline that generated this"
        },
        "model": {
          "type": "string",
          "description": "LLM model used"
        },
        "modelProvider": {
          "type": "string",
          "description": "LLM provider (anthropic, openai, etc.)"
        },
        "schemaVersion": {
          "type": "string",
          "description": "Version of this schema"
        }
      }
    },
    "JobSummary": {
      "type": "object",
      "required": ["documentPath", "title", "company"],
      "properties": {
        "documentPath": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "location": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compensation": {
          "type": "string"
        }
      }
    },
    "ProfileSummary": {
      "type": "object",
      "required": ["profileId", "profilePath", "name"],
      "properties": {
        "profileId": {
          "type": "string"
        },
        "profilePath": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "currentRole": {
          "type": "string"
        }
      }
    },
    "MatchResult": {
      "type": "object",
      "required": ["overallScore", "weightedScore", "categories", "findings"],
      "properties": {
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "0-100 percentage match"
        },
        "weightedScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "0-10 scale (structured-evaluation compatible)"
        },
        "categories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MatchCategory"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MatchFinding"
          }
        }
      }
    },
    "MatchCategory": {
      "type": "object",
      "required": ["category", "weight", "score", "status", "matchType", "justification"],
      "properties": {
        "category": {
          "$ref": "#/$defs/MatchCategoryType"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for this category (should sum to ~1.0)"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "maxScore": {
          "type": "number",
          "default": 10
        },
        "status": {
          "$ref": "#/$defs/ScoreStatus"
        },
        "matchType": {
          "$ref": "#/$defs/MatchType"
        },
        "justification": {
          "type": "string",
          "description": "Why this score was given"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supporting proof points"
        },
        "jdRequirement": {
          "type": "string",
          "description": "What the JD asked for"
        },
        "profileMatch": {
          "type": "string",
          "description": "What the profile has"
        }
      }
    },
    "MatchCategoryType": {
      "type": "string",
      "enum": [
        "technical_skills",
        "domain_experience",
        "leadership",
        "years_experience",
        "education",
        "industry_knowledge",
        "communication",
        "cultural_fit",
        "platform_scale",
        "apis_sdks",
        "developer_relations",
        "identity_security",
        "compliance",
        "thought_leadership",
        "team_management",
        "cross_functional"
      ],
      "description": "Standard match dimensions"
    },
    "MatchType": {
      "type": "string",
      "enum": ["exact", "semantic", "partial", "threshold", "boolean", "weighted"],
      "description": "How this category was evaluated"
    },
    "ScoreStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "needs_improvement"],
      "description": "Category status (pass >= 7.0, warn >= 5.0, fail < 5.0)"
    },
    "MatchFinding": {
      "type": "object",
      "required": ["id", "category", "findingType", "severity", "title", "description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique finding ID (S001 for strength, G001 for gap)"
        },
        "category": {
          "$ref": "#/$defs/MatchCategoryType"
        },
        "findingType": {
          "type": "string",
          "enum": ["strength", "gap"]
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "effort": {
          "$ref": "#/$defs/EffortLevel"
        }
      }
    },
    "Severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"],
      "description": "Finding severity (critical/high block, medium addressable, low/info informational)"
    },
    "EffortLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "MatchDecision": {
      "type": "object",
      "required": ["status", "passed", "rationale", "findingCounts", "overallScore"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "conditional", "fail", "human_review"]
        },
        "passed": {
          "type": "boolean"
        },
        "rationale": {
          "type": "string"
        },
        "findingCounts": {
          "$ref": "#/$defs/FindingCounts"
        },
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "weightedScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "FindingCounts": {
      "type": "object",
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "ActionItem": {
      "type": "object",
      "required": ["action", "category", "severity", "effort"],
      "properties": {
        "action": {
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/MatchCategoryType"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "effort": {
          "$ref": "#/$defs/EffortLevel"
        },
        "owner": {
          "type": "string"
        }
      }
    }
  }
}
